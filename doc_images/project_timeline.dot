digraph timeline {
 rankdir=LR;
 node [shape=record, style=filled, fillcolor=lightgrey, fontname=Helvetica, fontsize=10];
 Planning [label="{Planning & Analysis|Week 1-2|Requirements gathering\nArchitecture design\nDatabase design}"];
 Development [label="{Core Development|Week 3-8|Authentication\nTasks\nHabits\nAnalytics}"];
 UIUX [label="{UI/UX & Polish|Week 9-12|Responsive UI\nDark mode\nAnimations}"];
 Testing [label="{Testing & Optimization|Week 13-15|Tests\nPerformance\nSecurity}"];
 Deployment [label="{Deployment|Week 16|Release\nDocumentation}"];
 Planning -> Development [style=invis];
 Development -> UIUX [style=invis];
 UIUX -> Testing [style=invis];
 Testing -> Deployment [style=invis];
}
